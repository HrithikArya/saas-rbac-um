# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=Host=localhost;Port=5432;Database=saas_dev;Username=saas;Password=saas_secret

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Change before production!
JWT_SECRET=replace-me-with-a-long-random-secret-32chars+

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs for plans
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_TEAM=price_...

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000

# ─── Logging (Seq) ────────────────────────────────────────────────────────────
SEQ_URL=http://localhost:5341

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
ASPNETCORE_ENVIRONMENT=Development

# ─── Production only ──────────────────────────────────────────────────────────
